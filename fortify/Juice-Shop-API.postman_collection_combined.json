{
  "info": {
    "_postman_id": "ef0d7b8a-5ce1-421d-9b3d-b2cc1d1e83ef",
    "name": "Juice Shop API - Collection",
    "description": "Postman collection for Juice Shop /api and /rest endpoints. Set collection variable 'baseUrl' (default [http://localhost:3000](http://localhost:3000)). Login request stores JWT into collection variable 'jwt'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "13859659",
    "_collection_link": "https://go.postman.co/collection/13859659-ef0d7b8a-5ce1-421d-9b3d-b2cc1d1e83ef?source=collection_link"
  },
  "item": [
    {
      "name": "Auth / Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Access token returned\", function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.authentication.token).exist;",
              "    console.log('Saving JWT access token in collection: ' + json.authentication.token)",
              "    pm.collectionVariables.set(\"jwt\", json.authentication.token)",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"jim@juice-sh.op\",\n  \"password\": \"ncc-1701\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/user/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "rest",
            "user",
            "login"
          ]
        }
      },
      "response": []
